NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# Optional manual ad unit slot. Leave blank if you only use Auto ads.
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT_ID=
